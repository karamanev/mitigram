{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
  },
  "moduleNameMapper": {
    "@mitigram/shared": "<rootDir>/../../packages/shared/src/index.ts"
  },
  "testTimeout": 30000
}
